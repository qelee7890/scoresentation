{
  "name": "scoresentation",
  "version": "1.3.2",
  "private": true,
  "type": "module",
  "main": "main.js",
  "description": "Church hymn presentation and score editor",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "build": "electron-builder --win",
    "build-icon": "node tools/build-icon.mjs",
    "publish": "electron-builder --win --publish always",
    "server": "python tools/server.py",
    "sync-baseline": "python tools/sync-to-baseline.py"
  },
  "build": {
    "appId": "com.scoresentation.app",
    "productName": "Scoresentation",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.cjs",
      "main/**",
      "fonts/**",
      "src/**",
      "!data/**"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*",
          "!*.bak.*",
          "!*.db-shm",
          "!*.db-wal"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/music_presenter_icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "qelee7890",
      "repo": "scoresentation",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dompurify": "^3.0.11",
    "electron-updater": "^6.8.3",
    "katex": "^0.16.9",
    "marked": "^12.0.2"
  }
}
